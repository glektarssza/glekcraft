            "detail": "Clean up code coverage.",
            "icon": {
                "id": "trashcan",
                "color": "terminal.ansiWhite"
            },
            "dependsOn": [],
            "dependsOrder": "sequence",
            "group": "none",
            "isBackground": false,
            "promptOnClose": false,
            "type": "shell",
            "command": "find",
            "args": [
                "${workspaceFolder}",
                "-depth",
                "-type",
                "f",
                "-iname",
                "coverage.cobertura.xml",
                "-delete"
