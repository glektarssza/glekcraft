{
    "version": "0.2.0",
    "configurations": [
        {
            "name": ".NET Core Attach",
            "type": "coreclr",
            "request": "attach"
        },
        {
            "name": ".NET Core Launch",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "dotnet:build",
            "program": "${workspaceFolder}/Glekcraft/bin/Debug/net8.0/Glekcraft.dll",
            "args": [],
            "cwd": "${workspaceFolder}",
            "stopAtEntry": false,
            "console": "internalConsole"
        },
        {
            "name": "C#: Glekcraft Debug",
            "type": "dotnet",
            "request": "launch",
            "projectPath": "${workspaceFolder}/Glekcraft/Glekcraft.csproj",
            "preLaunchTask": "dotnet:build"
        }
    ]
}
