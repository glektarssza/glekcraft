{
    "name": "Require branches to use naming convention",
    "target": "branch",
    "enforcement": "active",
    "conditions": {
        "ref_name": {
            "exclude": [
                "refs/heads/bug/*",
                "refs/heads/bug/**/*",
                "refs/heads/bugfix/*",
                "refs/heads/bugfix/**/*",
                "refs/heads/bugfixes/*",
                "refs/heads/bugfixes/**/*",
                "refs/heads/bugs/*",
                "refs/heads/bugs/**/*",
                "refs/heads/chore/*",
                "refs/heads/chore/**/*",
                "refs/heads/chores/*",
                "refs/heads/chores/**/*",
                "refs/heads/dependabot/*",
                "refs/heads/dependabot/**/*",
                "refs/heads/dependencies/*",
                "refs/heads/dependencies/**/*",
                "refs/heads/dependency/*",
                "refs/heads/dependency/**/*",
                "refs/heads/feature/*",
                "refs/heads/feature/**/*",
                "refs/heads/features/*",
                "refs/heads/features/**/*",
                "refs/heads/hotfix/*",
                "refs/heads/hotfix/**/*",
                "refs/heads/hotfixes/*",
                "refs/heads/hotfixes/**/*",
                "refs/heads/refactor/*",
                "refs/heads/refactor/**/*",
                "refs/heads/refactoring/*",
                "refs/heads/refactoring/**/*",
                "refs/heads/refactors/*",
                "refs/heads/refactors/**/*",
                "refs/heads/release/*",
                "refs/heads/release/**/*",
                "refs/heads/security/*",
                "refs/heads/security/**/*",
                "refs/heads/task/*",
                "refs/heads/task/**/*",
                "refs/heads/tasks/*",
                "refs/heads/tasks/**/*"
            ],
            "include": ["~ALL"]
        }
    },
    "rules": [
        {
            "type": "creation"
        }
    ],
    "bypass_actors": []
}
