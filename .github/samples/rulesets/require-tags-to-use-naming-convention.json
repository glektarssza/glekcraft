    "target": "tag",
    "enforcement": "active",
    "conditions": {
        "ref_name": {
            "exclude": ["refs/tags/v*"],
            "include": ["~ALL"]
        }
    },
    "rules": [
        {
            "type": "creation"
        }
    ],
    "bypass_actors": []
}
